# Advanced non-interactive config for: .\init-config.ps1 -UseEnv
# Default path is interactive (no .env required). Copy to .env only if you use -UseEnv.
#
# Missing PRIMARY_BASE_URL / BACKUP_BASE_URL fields => built-in defaults below.
# Empty or omitted BACKUP_API_KEY => skip backup upstream entirely.

PRIMARY_BASE_URL=https://api.muskapi.cc/v1
PRIMARY_API_KEY=

BACKUP_BASE_URL=https://ai.centos.hk/v1
BACKUP_API_KEY=

# Optional path overrides
CPA_CONFIG=C:\CLIProxyAPI\config.yaml
BIFROST_DATA=C:\bifrost\data
CPA_BASE_URL=http://host.docker.internal:8317/v1
CPA_API_KEY=sk-cpa-local
